# Bunny.net Stream
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_TOKEN_KEY=
BUNNY_PULL_ZONE=
# Only needed if Token Authentication is enabled on the pull zone (Library > API >
# "CDN zone management" > Manage > Security > Token Authentication). Signs thumbnail
# URLs so they aren't blocked with a 403. Leave blank if Token Authentication is off.
BUNNY_CDN_TOKEN_KEY=

# Required. Public base URL used to build every emailed link (e.g.
# https://your-app.example.com, or http://localhost:3000 in dev). The app
# fails loudly if this is unset — it never falls back to the request's Host
# header, which a client can spoof (host header poisoning).
SITE_URL=

# Admin login (Basic Auth for the / page)
ADMIN_USER=
ADMIN_PASS=

# Optional: comma/space-separated ISO 3166-1 alpha-2 country codes (e.g.
# "US, CA") allowed to reach /watch and /bundle pages. Deliberately an env
# var, not a Settings-panel field, so the list itself can't be mistyped and
# saved instantly from the admin UI. Also requires the "Enforce the geo
# whitelist" toggle in Settings (off by default) to actually take effect.
GEO_WHITELIST=

# Same idea, but for the admin page and its API routes, on top of
# ADMIN_USER/ADMIN_PASS. Also an env var (not a Settings field) for the same
# reason, with an extra one: it must stay editable outside the app so a
# lockout is always fixable from your hosting dashboard. Also requires the
# "Enforce the admin geo whitelist" toggle in Settings (off by default).
ADMIN_GEO_WHITELIST=

# Optional: comma/space-separated Basic Auth usernames (matched
# case-insensitively) that always skip the admin geo check above, regardless
# of country or the enforcement toggle. Arm this BEFORE traveling — it's a
# standing safety net, not an in-the-moment fix, since env var changes need
# a redeploy.
ADMIN_GEO_BYPASS_EMAILS=

# Secret used to sign the email-gated "magic link" grants and viewer cookies.
# Set to a long random string, e.g. `openssl rand -hex 32`. Required for the
# /watch pages to work.
GATE_SECRET=

# Email delivery.
# Preferred: Resend HTTP API. Set RESEND_API_KEY and RESEND_FROM (a verified
# sender on your Resend domain) and email is sent via the Resend API.
RESEND_API_KEY=
RESEND_FROM=

# Fallback: plain SMTP via any provider (Brevo, SMTP2GO, Gmail app password,
# etc.). Only used when RESEND_API_KEY is not set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Storage (Upstash Redis REST API - via Vercel Storage tab or upstash.com)
KV_REST_API_URL=
KV_REST_API_TOKEN=
