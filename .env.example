# Bunny.net Stream
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_TOKEN_KEY=
BUNNY_PULL_ZONE=
# Only needed if Token Authentication is enabled on the pull zone (Library > API >
# "CDN zone management" > Manage > Security > Token Authentication). Signs thumbnail
# URLs so they aren't blocked with a 403. Leave blank if Token Authentication is off.
BUNNY_CDN_TOKEN_KEY=

# Site
SITE_URL=

# Admin login (Basic Auth for the / page)
ADMIN_USER=
ADMIN_PASS=

# Secret used to sign the email-gated "magic link" grants and viewer cookies.
# Set to a long random string, e.g. `openssl rand -hex 32`. Required for the
# /watch pages to work.
GATE_SECRET=

# SMTP (any provider: Resend, Brevo, SMTP2GO, Gmail app password, etc.)
# For Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=587, SMTP_USER=resend,
# SMTP_PASS=<your Resend API key>, SMTP_FROM=you@your-verified-domain.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Storage (Upstash Redis REST API - via Vercel Storage tab or upstash.com)
KV_REST_API_URL=
KV_REST_API_TOKEN=
